<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Emma & Georges, 11 septembre, Kesserwan</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,500;0,9..144,600;1,9..144,400;1,9..144,500&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --stone:#F5F0E4;
    --stone-deep:#ECE4D2;
    --pine:#3E4C40;
    --pine-deep:#2B352C;
    --dusk:#7C6B86;
    --dusk-deep:#584A63;
    --amber:#D9A657;
    --ember:#E8935B;
    --ink:#2B322D;
    --ink-soft:#5B6459;
    --white:#FFFDF8;
  }
  *{box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    margin:0;
    background:var(--stone);
    color:var(--ink);
    font-family:'Jost', sans-serif;
    font-weight:400;
    overflow-x:hidden;
  }
  h1,h2,h3,.display{ font-family:'Fraunces', serif; font-weight:500; margin:0; }
  .eyebrow{
    font-family:'Jost', sans-serif;
    letter-spacing:0.28em;
    text-transform:uppercase;
    font-size:0.72rem;
    color:var(--ink-soft);
  }
  a{ color:inherit; }
  img{ max-width:100%; display:block; }

  /* ---------- sticky nav ---------- */
  nav.tabs{
    position:sticky; top:0; z-index:50;
    display:flex; justify-content:center; gap:clamp(0.8rem,3vw,2.2rem);
    padding:0.9rem 4vw;
    background:rgba(245,240,228,0.85);
    backdrop-filter:blur(10px);
    border-bottom:1px solid rgba(62,76,64,0.12);
    overflow-x:auto;
    white-space:nowrap;
  }
  nav.tabs a{
    font-size:0.78rem;
    letter-spacing:0.05em;
    text-transform:uppercase;
    text-decoration:none;
    color:var(--ink-soft);
    padding:0.3rem 0.2rem;
    border-bottom:2px solid transparent;
    transition:border-color 0.15s ease, color 0.15s ease;
  }
  nav.tabs a:hover, nav.tabs a:focus-visible{ color:var(--ink); border-color:var(--amber); }

  /* ---------- firefly / ember animation ---------- */
  .ember-layer{ position:absolute; inset:0; overflow:hidden; pointer-events:none; z-index:1; }
  .ember{
    position:absolute;
    width:5px; height:5px;
    border-radius:50%;
    background:var(--amber);
    box-shadow:0 0 8px 2px rgba(217,166,87,0.8);
    opacity:0;
    animation: rise linear infinite;
  }
  @keyframes rise{
    0%{ transform:translateY(0) translateX(0); opacity:0; }
    10%{ opacity:0.9; }
    90%{ opacity:0.5; }
    100%{ transform:translateY(-70vh) translateX(20px); opacity:0; }
  }
  @media (prefers-reduced-motion: reduce){ .ember{ animation:none !important; opacity:0.5; } }

  /* ---------- hero ---------- */
  .hero{
    position:relative;
    min-height:100svh;
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    text-align:center;
    padding:8vh 6vw 12vh;
    background:linear-gradient(180deg, var(--dusk-deep) 0%, var(--dusk) 32%, var(--ember) 68%, var(--stone) 100%);
  }
  .mountains{
    position:absolute; left:0; right:0; bottom:0; width:100%; z-index:1; line-height:0;
  }
  .hero-content{ position:relative; z-index:2; }
  .hero .eyebrow{ color:rgba(255,253,248,0.85); margin-bottom:1.6rem; }
  .hero h1{
    font-size:clamp(3rem, 10vw, 6.4rem);
    line-height:0.98;
    color:var(--white);
  }
  .amp{
    display:block;
    font-family:'Fraunces', serif;
    font-style:italic;
    font-weight:400;
    font-size:0.5em;
    color:var(--amber);
    margin:0.1em 0;
  }
  .hero-sub{
    margin-top:2rem;
    font-size:1.05rem;
    color:rgba(255,253,248,0.92);
    max-width:38ch;
  }
  .hero-date{ margin-top:3rem; display:flex; align-items:center; gap:1.1rem; }
  .hero-date .day{
    font-family:'Fraunces', serif;
    font-size:3.4rem; font-weight:600;
    color:var(--white);
    line-height:1;
  }
  .hero-date .rest{ text-align:left; font-size:0.92rem; line-height:1.5; color:rgba(255,253,248,0.92); }
  .hero-date .rest b{ display:block; font-family:'Fraunces', serif; font-size:1.05rem; font-weight:600; color:var(--white); }


  /* ---------- section shell ---------- */
  section{ position:relative; padding:6.5rem 6vw; }
  .section-inner{ max-width:780px; margin:0 auto; }

  /* ---------- histoire ---------- */
  .histoire{ background:var(--stone); text-align:center; }
  .histoire .eyebrow{ display:block; margin-bottom:0.9rem; }
  .histoire h2{ font-size:clamp(1.8rem,4vw,2.6rem); margin-bottom:1.5rem; }
  .histoire p{ color:var(--ink-soft); line-height:1.85; font-size:1.02rem; }
  .timeline{
    display:flex; justify-content:center; gap:2.5rem; margin-top:2.6rem; flex-wrap:wrap;
  }
  .timeline .step{ max-width:220px; text-align:center; }
  .timeline .step .dot{
    width:12px; height:12px; border-radius:50%; background:var(--amber);
    margin:0 auto 0.8rem;
  }
  .timeline .step b{ display:block; font-family:'Fraunces', serif; font-size:1.1rem; margin-bottom:0.3rem; }
  .timeline .step span{ font-size:0.85rem; color:var(--ink-soft); }
  .timeline .connector{ width:60px; height:1px; background:rgba(91,100,89,0.3); align-self:center; margin-top:6px; }

  /* ---------- infos ---------- */
  .infos{ background:var(--white); }
  .infos > .section-inner > .eyebrow{ display:block; text-align:center; margin-bottom:0.8rem; }
  .infos h2{ font-size:clamp(1.8rem,4vw,2.6rem); text-align:center; }
  .infos-grid{ display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:2.2rem; margin-top:2.6rem; }
  .info-card{
    padding:1.9rem 1.6rem; border-radius:18px;
    background:var(--stone);
    border:1px solid rgba(217,166,87,0.28);
    text-align:left;
  }
  .info-card .icon{ width:38px; height:38px; border-radius:50%; display:flex; align-items:center; justify-content:center; margin-bottom:1rem; font-size:1.1rem; }
  .info-card h3{ font-size:1.15rem; margin-bottom:0.5rem; }
  .info-card p{ color:var(--ink-soft); font-size:0.94rem; line-height:1.6; margin:0; }
  .info-card a.map-link{ display:inline-block; margin-top:0.7rem; font-size:0.85rem; color:var(--dusk-deep); text-decoration:underline; text-underline-offset:3px; }


  /* ---------- RSVP ---------- */
  .rsvp{ background:linear-gradient(180deg, var(--stone) 0%, var(--stone-deep) 100%); }
  .rsvp .section-inner{ text-align:center; }
  .rsvp h2{ font-size:clamp(1.8rem,4vw,2.6rem); }
  .rsvp .deadline{ margin-top:0.8rem; font-size:0.92rem; color:var(--ink-soft); }
  form#rsvp-form{
    margin-top:2.6rem; text-align:left;
    background:var(--white); border-radius:24px; padding:2.4rem 2rem;
    box-shadow:0 20px 50px -20px rgba(43,50,45,0.25);
  }
  .field{ margin-bottom:1.5rem; }
  .field label{ display:block; font-size:0.78rem; letter-spacing:0.08em; text-transform:uppercase; color:var(--ink-soft); margin-bottom:0.55rem; }
  .field input[type=text], .field input[type=number], .field input[type=url], .field textarea{
    width:100%; padding:0.85rem 1rem; border-radius:12px;
    border:1.5px solid rgba(91,100,89,0.25);
    background:var(--stone);
    font-family:'Jost', sans-serif; font-size:1rem; color:var(--ink);
  }
  .field input:focus, .field textarea:focus{ outline:none; border-color:var(--amber); box-shadow:0 0 0 3px rgba(217,166,87,0.22); }
  .field textarea{ resize:vertical; min-height:90px; }
  .presence-toggle{ display:flex; gap:0.9rem; }
  .presence-toggle button{
    flex:1; padding:0.9rem 1rem; border-radius:12px;
    border:1.5px solid rgba(91,100,89,0.25);
    background:var(--stone); font-family:'Jost', sans-serif; font-size:0.95rem; color:var(--ink);
    cursor:pointer; transition:all 0.15s ease;
  }
  .presence-toggle button.selected.yes{ background:var(--pine); border-color:var(--pine); color:var(--white); }
  .presence-toggle button.selected.no{ background:var(--ember); border-color:var(--ember); color:var(--white); }
  .presence-toggle button:focus-visible{ outline:2px solid var(--amber); outline-offset:2px; }
  #guests-field{ display:none; }
  .submit-btn{
    width:100%; padding:1rem; border-radius:12px; border:none;
    background:var(--ink); color:var(--white);
    font-family:'Jost', sans-serif; font-size:1rem; letter-spacing:0.03em; cursor:pointer;
    transition:transform 0.15s ease, background 0.15s ease;
  }
  .submit-btn:hover{ background:var(--pine-deep); }
  .submit-btn:active{ transform:scale(0.98); }
  .submit-btn:disabled{ opacity:0.6; cursor:default; }
  .form-msg{ margin-top:1.1rem; font-size:0.9rem; text-align:center; min-height:1.2em; }
  .form-msg.error{ color:#B5533B; }
  .form-msg.success{ color:#4F7A4A; }
  .confirmation{ display:none; text-align:center; padding:2.4rem 2rem; }
  .confirmation .stamp{ width:54px; height:54px; border-radius:50%; background:var(--pine); color:var(--white); display:flex; align-items:center; justify-content:center; font-size:1.5rem; margin:0 auto 1.2rem; }

  /* ---------- galerie ---------- */
  .galerie{ background:var(--white); }
  .galerie .section-inner{ text-align:center; }
  .galerie h2{ font-size:clamp(1.8rem,4vw,2.6rem); }
  .galerie p.intro{ color:var(--ink-soft); margin-top:1rem; line-height:1.7; max-width:56ch; margin-left:auto; margin-right:auto; }
  .upload-box{
    margin-top:2.4rem; text-align:left;
    background:var(--stone); border-radius:24px; padding:2rem 1.8rem;
  }
  .upload-row{ display:flex; gap:1rem; flex-wrap:wrap; }
  .upload-row .field{ flex:1; min-width:220px; }
  .file-input-wrap{
    display:flex; align-items:center; gap:0.8rem;
    border:1.5px dashed rgba(91,100,89,0.35); border-radius:12px;
    padding:0.85rem 1rem; background:var(--white); cursor:pointer;
  }
  .file-input-wrap input[type=file]{ display:none; }
  .file-input-wrap .label-text{ font-size:0.9rem; color:var(--ink-soft); }
  .upload-submit{
    padding:0.85rem 1.6rem; border-radius:12px; border:none;
    background:var(--pine); color:var(--white); font-family:'Jost', sans-serif;
    font-size:0.95rem; cursor:pointer; margin-top:0.4rem;
  }
  .upload-submit:disabled{ opacity:0.6; }
  .gallery-grid{
    margin-top:2.8rem;
    columns:3 220px; column-gap:1rem;
  }
  .gallery-item{
    break-inside:avoid; margin-bottom:1rem; border-radius:14px; overflow:hidden;
    background:var(--stone); border:1px solid rgba(217,166,87,0.2);
  }
  .gallery-item img{ width:100%; border-radius:14px 14px 0 0; }
  .gallery-item .meta{ padding:0.7rem 0.9rem 0.9rem; }
  .gallery-item .meta .who{ font-size:0.85rem; font-weight:500; }
  .gallery-item .meta .caption{ font-size:0.82rem; color:var(--ink-soft); margin-top:0.2rem; }
  .empty-gallery{ margin-top:2.8rem; font-size:0.9rem; color:var(--ink-soft); font-style:italic; }

  /* ---------- footer ---------- */
  footer{ background:var(--pine-deep); color:rgba(245,240,228,0.75); text-align:center; padding:4rem 6vw 3rem; font-size:0.85rem; }
  footer .footer-names{ font-family:'Fraunces', serif; font-style:italic; font-size:1.3rem; color:var(--white); margin-bottom:1.4rem; }

  @media (max-width:640px){
    section{ padding:5rem 6vw; }
    .hero-date{ gap:0.8rem; }
    form#rsvp-form{ padding:1.8rem 1.3rem; }
    .gallery-grid{ columns:2 160px; }
  }
</style>
</head>
<body>

<nav class="tabs">
  <a href="#accueil">Accueil</a>
  <a href="#histoire">Notre histoire</a>
  <a href="#infos">Infos</a>
  <a href="#rsvp">RSVP</a>
  <a href="#galerie">Galerie</a>
</nav>

<!-- ============ HERO ============ -->
<section class="hero" id="accueil">
  <div class="ember-layer" id="hero-embers"></div>
  <svg class="mountains" viewBox="0 0 1440 180" preserveAspectRatio="none" style="height:140px;">
    <path d="M0,180 L0,110 L180,50 L320,95 L480,30 L640,90 L800,45 L980,100 L1140,55 L1300,95 L1440,60 L1440,180 Z" fill="#3E4C40"></path>
    <path d="M0,180 L0,140 L220,90 L420,130 L620,75 L860,135 L1080,85 L1260,125 L1440,100 L1440,180 Z" fill="#2B352C" opacity="0.85"></path>
  </svg>
  <div class="hero-content">
    <div class="eyebrow">On continue la fête</div>
    <h1>Emma<span class="amp">&amp;</span>Georges</h1>
    <p class="hero-sub">Mariés en France, on continue la fête au Liban : Une soirée à Al Nassamat avec vous.</p>
    <div class="hero-date">
      <div class="day">11</div>
      <div class="rest"><b>Septembre 2026</b>À partir de 19h<br>Al Nassamat, Kesserwan, Liban</div>
    </div>
  </div>

</section>

<!-- ============ NOTRE HISTOIRE ============ -->
<section class="histoire" id="histoire">
  <div class="section-inner">
    <span class="eyebrow">Un mariage, deux célébrations</span>
    <h2>On s'est dit oui en France, on le fête au Liban</h2>
    <p>Le 13 décembre 2025, on s'est dit oui à la mairie de Lyon 7, en petit comité. Le 11 septembre, on continue la fête au Liban, à Al Nassamat, avec celles et ceux qu'on aime le plus.</p>
    <div class="timeline">
      <div class="step">
        <div class="dot"></div>
        <b>13 décembre 2025</b>
        <span>Mariage civil, mairie de Lyon 7</span>
      </div>
      <div class="connector"></div>
      <div class="step">
        <div class="dot"></div>
        <b>11 septembre 2026</b>
        <span>Fête au Liban, à Al Nassamat</span>
      </div>
    </div>
  </div>
</section>

<!-- ============ INFOS PRATIQUES ============ -->
<section class="infos" id="infos">
  <div class="section-inner">
    <span class="eyebrow">Informations pratiques</span>
    <h2>Le jour J</h2>
    <div class="infos-grid">
      <div class="info-card">
        <div class="icon" style="background:var(--amber);">📅</div>
        <h3>Date</h3>
        <p>Vendredi 11 septembre 2026</p>
      </div>
      <div class="info-card">
        <div class="icon" style="background:var(--dusk);">🕖</div>
        <h3>Heure</h3>
        <p>Accueil à partir de 19h</p>
      </div>
      <div class="info-card">
        <div class="icon" style="background:var(--pine); color:var(--white);">📍</div>
        <h3>Lieu</h3>
        <p>Al Nassamat, Kesserwan, Liban</p>
        <a class="map-link" href="https://www.google.com/maps/search/?api=1&query=Al%20Nassamat%20Kesserwan%20Liban" target="_blank" rel="noopener">Voir sur la carte →</a>
      </div>
    </div>
  </div>
</section>

<!-- ============ RSVP ============ -->
<section class="rsvp" id="rsvp">
  <div class="section-inner">
    <span class="eyebrow">RSVP</span>
    <h2>Serez-vous des nôtres ?</h2>
    <p class="deadline">Merci de confirmer avant le <strong>dimanche 6 septembre</strong>.</p>

    <form id="rsvp-form" novalidate>
      <div class="field">
        <label for="name">Votre nom</label>
        <input type="text" id="name" name="name" required autocomplete="name" placeholder="Prénom et nom">
      </div>

      <div class="field">
        <label>Présence</label>
        <div class="presence-toggle" role="group" aria-label="Confirmez votre présence">
          <button type="button" class="presence-btn yes" data-value="yes">Je serai là 🎉</button>
          <button type="button" class="presence-btn no" data-value="no">Je ne pourrai pas venir</button>
        </div>
      </div>

      <div class="field" id="guests-field">
        <label for="guests">Nombre de personnes (vous inclus·e)</label>
        <input type="number" id="guests" name="guests" min="1" max="10" value="1">
      </div>

      <div class="field">
        <label for="message">Un petit mot pour Emma &amp; Georges (facultatif)</label>
        <textarea id="message" name="message" placeholder="..."></textarea>
      </div>

      <button type="submit" class="submit-btn" id="submit-btn">Envoyer ma réponse</button>
      <div class="form-msg" id="form-msg" role="status"></div>
    </form>

    <div class="confirmation" id="confirmation">
      <div class="stamp">✓</div>
      <h3 style="font-size:1.4rem;">Merci !</h3>
      <p style="color:var(--ink-soft); margin-top:0.6rem;">Votre réponse a bien été enregistrée. On a hâte de vous voir à Al Nassamat.</p>
    </div>
  </div>
</section>

<!-- ============ GALERIE ============ -->
<section class="galerie" id="galerie">
  <div class="section-inner">
    <span class="eyebrow">Après la fête</span>
    <h2>Partagez vos photos</h2>
    <p class="intro">Vous avez pris une jolie photo pendant la soirée ? Ajoutez-la ici, gardons tous ces souvenirs ensemble.</p>

    <div class="upload-box">
      <form id="gallery-form" novalidate>
        <div class="field">
          <label for="gallery-name">Votre nom</label>
          <input type="text" id="gallery-name" placeholder="Prénom">
        </div>

        <div class="upload-row">
          <div class="field" style="flex-basis:100%;">
            <label>Photo</label>
            <label class="file-input-wrap" id="file-wrap">
              <input type="file" id="gallery-file" accept="image/*">
              <span class="label-text" id="file-label-text">Choisir une photo…</span>
            </label>
          </div>
        </div>

        <div class="field">
          <label for="gallery-caption">Petite légende (facultatif)</label>
          <input type="text" id="gallery-caption" placeholder="Un mot sur ce moment">
        </div>

        <button type="submit" class="upload-submit" id="gallery-submit">Ajouter à la galerie</button>
        <div class="form-msg" id="gallery-msg" role="status"></div>
      </form>
    </div>

    <div class="gallery-grid" id="gallery-grid"></div>
    <div class="empty-gallery" id="empty-gallery">La galerie est vide pour le moment, soyez les premiers à partager un souvenir !</div>
  </div>
</section>

<!-- ============ FOOTER ============ -->
<footer>
  <div class="footer-names">Emma &amp; Georges</div>
  <div>11 septembre 2026 · Al Nassamat, Kesserwan, Liban</div>
  <div style="margin-top:1.6rem; font-size:0.75rem; opacity:0.6;">Les réponses RSVP sont envoyées directement par email aux mariés.</div>
</footer>

<script>
(function(){
  // ---------- ember decoration ----------
  const emberLayer = document.getElementById('hero-embers');
  for(let i=0;i<16;i++){
    const el = document.createElement('div');
    el.className = 'ember';
    const left = Math.random()*100;
    const dur = 8 + Math.random()*10;
    const delay = -Math.random()*18;
    const size = 3 + Math.random()*4;
    el.style.left = left + '%';
    el.style.bottom = (Math.random()*10) + '%';
    el.style.width = size + 'px';
    el.style.height = size + 'px';
    el.style.animationDuration = dur + 's';
    el.style.animationDelay = delay + 's';
    emberLayer.appendChild(el);
  }

  // ---------- RSVP form logic ----------
  const form = document.getElementById('rsvp-form');
  const presenceBtns = document.querySelectorAll('.presence-btn');
  const guestsField = document.getElementById('guests-field');
  const formMsg = document.getElementById('form-msg');
  const submitBtn = document.getElementById('submit-btn');
  const confirmation = document.getElementById('confirmation');
  let presenceValue = null;

  presenceBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      presenceBtns.forEach(b => b.classList.remove('selected','yes','no'));
      btn.classList.add('selected', btn.dataset.value);
      presenceValue = btn.dataset.value;
      guestsField.style.display = presenceValue === 'yes' ? 'block' : 'none';
      formMsg.textContent = '';
    });
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    formMsg.className = 'form-msg';
    const name = document.getElementById('name').value.trim();

    if(!name){
      formMsg.textContent = 'Merci d\'indiquer votre nom.';
      formMsg.className = 'form-msg error';
      return;
    }
    if(!presenceValue){
      formMsg.textContent = 'Merci de préciser si vous serez présent·e.';
      formMsg.className = 'form-msg error';
      return;
    }

    const guests = presenceValue === 'yes' ? (parseInt(document.getElementById('guests').value,10) || 1) : 0;
    const message = document.getElementById('message').value.trim();

    submitBtn.disabled = true;
    submitBtn.textContent = 'Envoi...';

    try{
      const response = await fetch('https://formspree.io/f/meeyazpv', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({
          Nom: name,
          Présence: presenceValue === 'yes' ? 'Présent·e' : 'Absent·e',
          'Nombre de personnes': guests,
          Message: message || '(aucun)'
        })
      });
      if(!response.ok){ throw new Error('Le serveur a refusé l\'envoi (' + response.status + ')'); }
      form.style.display = 'none';
      confirmation.style.display = 'block';
    }catch(err){
      formMsg.textContent = 'Un souci est survenu (' + (err && err.message ? err.message : 'erreur inconnue') + '). Réessayez dans un instant.';
      formMsg.className = 'form-msg error';
      submitBtn.disabled = false;
      submitBtn.textContent = 'Envoyer ma réponse';
    }
  });

  // ---------- gallery logic (Cloudinary) ----------
  const CLOUD_NAME = 'lfiye6jw';
  const UPLOAD_PRESET = 'emma_georges';
  const GALLERY_TAG = 'emma-georges-wedding';

  const galleryForm = document.getElementById('gallery-form');
  const galleryMsg = document.getElementById('gallery-msg');
  const gallerySubmit = document.getElementById('gallery-submit');
  const galleryGrid = document.getElementById('gallery-grid');
  const emptyGallery = document.getElementById('empty-gallery');
  const fileInput = document.getElementById('gallery-file');
  const fileLabelText = document.getElementById('file-label-text');

  fileInput.addEventListener('change', () => {
    fileLabelText.textContent = fileInput.files[0] ? fileInput.files[0].name : 'Choisir une photo…';
  });

  function escapeContextValue(str){
    return (str || '').replace(/\|/g, ',').replace(/=/g, '-');
  }

  function renderGalleryItem(resource){
    const ctx = (resource.context && resource.context.custom) ? resource.context.custom : (resource.context || {});
    const name = ctx.name || 'Anonyme';
    const caption = ctx.caption || '';
    const url = 'https://res.cloudinary.com/' + CLOUD_NAME + '/image/upload/w_700,q_auto,f_auto/' + resource.public_id + '.' + resource.format;
    const div = document.createElement('div');
    div.className = 'gallery-item';
    div.innerHTML = '<img src="' + url + '" alt="' + escapeHtml(caption || 'Photo de la soirée') + '" loading="lazy">' +
      '<div class="meta"><div class="who">' + escapeHtml(name) + '</div>' +
      (caption ? '<div class="caption">' + escapeHtml(caption) + '</div>' : '') + '</div>';
    return div;
  }

  async function loadGallery(){
    try{
      const res = await fetch('https://res.cloudinary.com/' + CLOUD_NAME + '/image/list/' + GALLERY_TAG + '.json');
      if(!res.ok){ throw new Error('Liste indisponible (' + res.status + ')'); }
      const data = await res.json();
      const resources = (data && data.resources) ? data.resources : [];
      resources.sort((a,b) => (b.version || 0) - (a.version || 0));
      galleryGrid.innerHTML = '';
      if(resources.length === 0){
        emptyGallery.textContent = 'La galerie est vide pour le moment, soyez les premiers à partager un souvenir !';
        emptyGallery.style.display = 'block';
      }else{
        emptyGallery.style.display = 'none';
        resources.forEach(resource => galleryGrid.appendChild(renderGalleryItem(resource)));
      }
    }catch(err){
      emptyGallery.textContent = 'Impossible de charger la galerie pour le moment (' + (err && err.message ? err.message : 'erreur inconnue') + ').';
      emptyGallery.style.display = 'block';
    }
  }

  galleryForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    galleryMsg.className = 'form-msg';
    const name = document.getElementById('gallery-name').value.trim();
    const caption = document.getElementById('gallery-caption').value.trim();
    const file = fileInput.files[0];

    if(!file){
      galleryMsg.textContent = 'Ajoutez une photo.';
      galleryMsg.className = 'form-msg error';
      return;
    }

    gallerySubmit.disabled = true;
    gallerySubmit.textContent = 'Envoi...';

    try{
      const formData = new FormData();
      formData.append('file', file);
      formData.append('upload_preset', UPLOAD_PRESET);
      formData.append('tags', GALLERY_TAG);
      formData.append('context', 'name=' + escapeContextValue(name || 'Anonyme') + '|caption=' + escapeContextValue(caption));

      const uploadRes = await fetch('https://api.cloudinary.com/v1_1/' + CLOUD_NAME + '/image/upload', {
        method: 'POST',
        body: formData
      });
      if(!uploadRes.ok){
        const errBody = await uploadRes.json().catch(() => null);
        throw new Error((errBody && errBody.error && errBody.error.message) ? errBody.error.message : ('Échec de l\'envoi (' + uploadRes.status + ')'));
      }

      galleryForm.reset();
      fileLabelText.textContent = 'Choisir une photo…';
      galleryMsg.textContent = 'Merci, c\'est ajouté à la galerie !';
      galleryMsg.className = 'form-msg success';
      await loadGallery();
    }catch(err){
      galleryMsg.textContent = 'Un souci est survenu (' + (err && err.message ? err.message : 'erreur inconnue') + ').';
      galleryMsg.className = 'form-msg error';
    }finally{
      gallerySubmit.disabled = false;
      gallerySubmit.textContent = 'Ajouter à la galerie';
    }
  });

  loadGallery();

  function escapeHtml(str){
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }
})();
</script>
</body>
</html>
